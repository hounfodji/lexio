# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# IA — fournisseur par défaut (compatible OpenAI). Serveur uniquement.
# Providers : mistral | openai | gemini | groq | openrouter | deepseek | cerebras
AI_PROVIDER=mistral
AI_API_KEY=your-provider-api-key
# AI_MODEL=mistral-small-latest   # optionnel (défaut selon le provider)

# Secret de chiffrement des clés API saisies par les utilisateurs (Réglages).
# Une chaîne aléatoire longue suffit. Sans elle, l'enregistrement de clé perso
# est désactivé (le défaut ci-dessus continue de fonctionner).
AI_KEY_SECRET=change-me-long-random-string

# Compat ascendante : si AI_API_KEY est absent, OPENAI_API_KEY est utilisé
# (provider openai).
# OPENAI_API_KEY=sk-...

# Active/désactive la voix HD (modèles in-browser ~80 Mo).
# Par défaut activée. Mettre à "false" en prod pour la cacher tant qu'elle est instable.
# NEXT_PUBLIC_HD_VOICE_ENABLED=false
